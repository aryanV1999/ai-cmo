# ==============================================
# REQUIRED - Core APIs
# ==============================================

# Database (PostgreSQL)
# Options: Neon.tech (free 0.5GB), Supabase (free 500MB), or local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_marketing_db?schema=public"

# Redis (for job queue and caching)
# Options: Upstash (free 10K commands/day), Redis Cloud (free 30MB), or local Redis
REDIS_URL="redis://localhost:6379"

# OpenAI (ChatGPT) - required for AI summaries and research
# Get from: https://platform.openai.com/
OPENAI_API_KEY="your-openai-api-key"


# Google PageSpeed Insights API (for Core Web Vitals)
# Get from: https://console.cloud.google.com/
GOOGLE_PAGESPEED_API_KEY="your-google-pagespeed-api-key"

# Optional local Chroma/Vector host (if used)
CHROMA_HOST="http://localhost:8000"

# ==============================================
# OPTIONAL - Competitor Analysis APIs
# ==============================================
# SEMrush API (for advanced competitor analysis)
# SEMRUSH_API_KEY="your-semrush-api-key"

# Ahrefs API (alternative to SEMrush)
# AHREFS_API_KEY="your-ahrefs-api-key"

# OpenPageRank API (free Domain Authority alternative)
OPENPAGERANK_API_KEY="your-openpagerank-key"


# App Configuration
# ==============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PDF_STORAGE_PATH="./storage/pdfs"
APIFY_API_TOKEN="your-apify-token"

# ==============================================
# Feature Flags
# ==============================================
ENABLE_REAL_COMPETITOR_API=false
ENABLE_CRM_SYNC=false
ENABLE_PDF_GENERATION=false

# Actor IDs (if using Apify scrapers)
APIFY_INSTAGRAM_ACTOR_ID='apify/instagram-profile-scraper'
APIFY_TWITTER_ACTOR_ID='apidojo/tweet-scraper'
APIFY_YOUTUBE_ACTOR_ID='streamers/youtube-scraper'
APIFY_TIKTOK_ACTOR_ID='clockworks/tiktok-scraper'
